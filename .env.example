# Configuration SMTP pour le formulaire de contact (OVH / Zimbra)
# Copiez ce fichier en .env.local et remplissez vos propres valeurs pour tester en local.
# Sur Vercel, configurez ces mêmes variables dans Project Settings > Environment Variables.

SMTP_HOST=
SMTP_PORT=
SMTP_USER=contact@ohiho.fr
SMTP_PASS=
CONTACT_TO=contact@ohiho.fr
