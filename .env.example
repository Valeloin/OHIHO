# Configuration SMTP pour le formulaire de contact (OVH / Zimbra)
# Copiez ce fichier en .env.local et remplissez vos propres valeurs pour tester en local.
# Sur Vercel, configurez ces mêmes variables dans Project Settings > Environment Variables.

SMTP_HOST=
SMTP_PORT=
SMTP_USER=contact@ohiho.fr
SMTP_PASS=
CONTACT_TO=contact@ohiho.fr

# Configuration Supabase (comptes clients, tickets de support, pièces jointes)
# Project Settings > API dans votre projet Supabase.
# Ces deux valeurs sont publiques par conception (protégées par les règles RLS).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL du site, utilisée pour construire le lien de confirmation d'inscription.
# En local : http://localhost:3000 — en production : https://ohiho.fr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Adresse qui reçoit les notifications de nouveaux tickets / réponses client.
# Optionnel : retombe sur CONTACT_TO si non défini.
TICKET_NOTIFY_TO=
